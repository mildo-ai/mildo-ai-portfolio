---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const tr = t(lang);

const meta = [
  { url: 'https://subswap.app',                      status: 'live', metrics: ['1K+ ingredients', '10 languages', '$0 infra'], color: 'emerald', span: 'md:col-span-4', icon: '🍅' },
  { url: 'https://cropcast.app',                     status: 'live', metrics: ['12 futures', '53 agents', 'Daily AI'],        color: 'blue',    span: 'md:col-span-2', icon: '🌾' },
  { url: 'https://www.threads.com/@fridgey_raid',    status: 'live', metrics: ['Neo4j KG', 'KAMIS data', 'Daily posts'],      color: 'orange',  span: 'md:col-span-2', icon: '🍳' },
  { url: 'https://www.threads.com/@pourandpair',     status: 'live', metrics: ['Drink KG', 'Pairing AI', 'Nightly posts'],    color: 'purple',  span: 'md:col-span-2', icon: '🍷' },
  { url: null,                                       status: 'soon', metrics: ['CIDOC CRM', 'Provenance KG', 'Market signals'],color: 'pink',    span: 'md:col-span-2', icon: '🎨' },
];

const colorMap: Record<string, { accent: string; glow: string; badge: string }> = {
  emerald: { accent: 'text-emerald-400', glow: 'from-emerald-500/8', badge: 'bg-emerald-400/10 text-emerald-400 border-emerald-400/20' },
  blue:    { accent: 'text-blue-400',    glow: 'from-blue-500/8',    badge: 'bg-blue-400/10 text-blue-400 border-blue-400/20' },
  orange:  { accent: 'text-orange-400',  glow: 'from-orange-500/8',  badge: 'bg-orange-400/10 text-orange-400 border-orange-400/20' },
  purple:  { accent: 'text-purple-400',  glow: 'from-purple-500/8',  badge: 'bg-purple-400/10 text-purple-400 border-purple-400/20' },
  pink:    { accent: 'text-pink-400',    glow: 'from-pink-500/8',    badge: 'bg-pink-400/10 text-pink-400 border-pink-400/20' },
};
---

<section id="products" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-up mb-16">
      <p class="font-mono text-sm text-[var(--color-accent)] mb-3">{tr.products.label}</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">{tr.products.title}</h2>
      <p class="text-[var(--color-text-secondary)] mt-4 max-w-xl">{tr.products.sub}</p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-6 gap-4 auto-rows-[240px]">
      {tr.products.items.map((p, i) => {
        const m = meta[i];
        const c = colorMap[m.color];
        return (
          <div class={`product-card fade-up ${m.span} rounded-xl border border-[var(--color-line)] bg-[var(--color-surface)] p-8 relative group overflow-hidden hover:border-[var(--color-line-accent)]`}>
            <div class={`absolute inset-0 bg-gradient-to-br ${c.glow} to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-xl`}></div>
            <div class="absolute top-4 right-5 text-5xl opacity-10 group-hover:opacity-20 transition-opacity select-none">{m.icon}</div>

            <div class="relative z-10 flex flex-col h-full">
              <div class="flex items-center gap-2.5 mb-3">
                <h3 class={`font-bold text-xl ${c.accent}`}>{p.name}</h3>
                {m.status === 'live' ? (
                  <span class={`text-[10px] font-mono px-2 py-0.5 rounded-sm border uppercase tracking-widest ${c.badge}`}>live</span>
                ) : (
                  <span class="text-[10px] font-mono px-2 py-0.5 rounded-sm bg-[var(--color-surface-3)] text-[var(--color-muted)] border border-[var(--color-line)] uppercase tracking-widest">soon</span>
                )}
              </div>
              <p class="text-xs text-[var(--color-muted)] mb-4 font-mono">{p.tagline}</p>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed flex-1">{p.description}</p>
              <div class="mt-auto">
                {m.url ? (
                  <a
                    href={m.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`inline-flex items-center gap-1.5 text-xs font-mono uppercase tracking-widest hover:gap-2.5 transition-all ${c.accent}`}
                  >
                    {tr.products.explore} <span>↗</span>
                  </a>
                ) : (
                  <span class="text-xs font-mono text-[var(--color-muted)] uppercase tracking-widest">{tr.products.comingSoon}</span>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
