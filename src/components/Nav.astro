---
const links = [
  { label: 'Services', href: '#services' },
  { label: 'Work', href: '#work' },
  { label: 'Stack', href: '#stack' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur-md border-b border-[var(--color-line)]">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="#" class="font-mono font-bold text-[var(--color-accent)] text-lg tracking-tight">
      &gt;_ mildo.ai
    </a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contact"
        class="text-sm font-medium px-4 py-2 bg-[var(--color-accent)] text-[var(--color-bg)] rounded-lg hover:opacity-90 transition-opacity"
      >
        Let's Talk
      </a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="mobile-toggle"
      class="md:hidden text-[var(--color-text-secondary)] hover:text-[var(--color-text)]"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12h18M3 6h18M3 18h18" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-[var(--color-line)] bg-[var(--color-bg)]/95 backdrop-blur-md">
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="mobile-link text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contact"
        class="mobile-link text-sm font-medium px-4 py-2 bg-[var(--color-accent)] text-[var(--color-bg)] rounded-lg text-center hover:opacity-90 transition-opacity"
      >
        Let's Talk
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
