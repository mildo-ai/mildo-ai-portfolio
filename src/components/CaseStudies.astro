---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const tr = t(lang);

const caseMeta = [
  {
    number: '01',
    title: 'claude-agents-hub — Cross-Project Agent Installer',
    url: 'https://github.com/mildo-ai/claude-agents-hub',
    tags: ['Claude Code', 'DGM-H', 'Shell', 'MCP', 'launchd', 'RTK'],
    metrics: [{ value: '80+' }, { value: '8+' }, { value: '5' }, { value: '90%' }],
  },
  {
    number: '02',
    title: 'Mildo Group v2 — 80-Agent Full-Company AI',
    url: null,
    tags: ['Claude API', 'Codex', 'RALPH Loop', 'Multi-Agent', 'Orchestration', 'DGM-H'],
    metrics: [{ value: '80' }, { value: '6' }, { value: '4' }, { value: '11' }],
  },
  {
    number: '03',
    title: 'Dual Neo4j KG — Food & Drink Threads Channels',
    url: null,
    tags: ['Neo4j', 'Knowledge Graph', 'Python', 'Threads API', 'KAMIS', 'Multi-Agent'],
    metrics: [{ value: '2' }, { value: '28K+' }, { value: '2' }, { value: '5+' }],
  },
  {
    number: '04',
    title: 'SubSwap — Full SaaS Launch in a Weekend',
    url: 'https://subswap.app',
    tags: ['React', 'TypeScript', 'Fuse.js', 'Cloudflare Pages', 'i18n', 'SEO'],
    metrics: [{ value: '1,054' }, { value: '3,572' }, { value: '10' }, { value: '$0' }],
  },
  {
    number: '05',
    title: 'mildo-gateway — Raspberry Pi Remote Orchestration',
    url: null,
    tags: ['Raspberry Pi', 'Slack API', 'SSH', 'Python', 'WoL', 'launchd'],
    metrics: [{ value: '2' }, { value: '10+' }, { value: 'Mac1+2' }, { value: '99%' }],
  },
];
---

<section id="work" class="py-24 md:py-32 bg-[var(--color-surface)]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-up mb-16">
      <p class="font-mono text-sm text-[var(--color-accent)] mb-3">{tr.caseStudies.label}</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">{tr.caseStudies.title}</h2>
      <p class="text-[var(--color-text-secondary)] mt-4 max-w-xl">{tr.caseStudies.sub}</p>
    </div>

    <div class="space-y-8">
      {caseMeta.map((meta, i) => {
        const c = tr.caseStudies.cases[i];
        if (!c) return null;
        return (
          <div class="fade-up rounded-xl border border-[var(--color-line)] bg-[var(--color-bg)] p-8 md:p-10 hover:border-[var(--color-line-accent)] transition-colors">
            <div class="flex items-start gap-6 mb-6">
              <span class="font-mono text-4xl font-bold text-[var(--color-surface-3)]">{meta.number}</span>
              <div class="flex-1">
                <div class="flex items-center gap-3 flex-wrap">
                  <h3 class="text-xl md:text-2xl font-semibold">{meta.title}</h3>
                  {meta.url && (
                    <a href={meta.url} target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-[var(--color-accent)] border border-[var(--color-line-accent)] px-2 py-0.5 rounded hover:bg-[var(--color-accent-dim)] transition-colors">
                      ↗ {tr.caseStudies.liveLabel}
                    </a>
                  )}
                </div>
                <p class="text-sm text-[var(--color-muted)] mt-1">{c.subtitle}</p>
              </div>
            </div>

            <p class="text-[var(--color-text-secondary)] leading-relaxed mb-6 max-w-3xl">{c.description}</p>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6 p-4 rounded-lg bg-[var(--color-surface)]">
              {meta.metrics.map((m, j) => (
                <div class="text-center">
                  <div class="font-mono text-xl font-bold text-[var(--color-accent)]">{m.value}</div>
                  <div class="text-xs text-[var(--color-muted)] mt-1">{c.metricLabels[j]}</div>
                </div>
              ))}
            </div>

            <div class="flex flex-wrap gap-2">
              {meta.tags.map((tag) => (
                <span class="text-xs font-mono px-3 py-1 rounded-full bg-[var(--color-accent-dim)] text-[var(--color-accent)] border border-[var(--color-line-accent)]">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
