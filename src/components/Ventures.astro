---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const tr = t(lang);

// Status key and URLs for the 6 BUs
const statusKey = ['building', 'active', 'rnd', 'active', 'active', 'active'];
const urls = [
  'https://mildo.farm',
  null,
  null,
  null,
  null,
  null,
];

const statusStyle: Record<string, string> = {
  active:   'text-[var(--color-accent-green)] bg-[var(--color-accent-green-dim)] border-green-500/20',
  building: 'text-amber-400 bg-amber-400/10 border-amber-400/20',
  rnd:      'text-blue-400 bg-blue-400/10 border-blue-400/20',
};

// BU number icons for visual variety
const buIcons = [
  // Smart Farm
  `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>`,
  // Digital Products
  `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>`,
  // R&D
  `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19 14.5" /></svg>`,
  // AI Consulting
  `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>`,
  // Trading
  `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>`,
  // HQ
  `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" /></svg>`,
];
---

<section id="ventures" class="py-24 md:py-32 bg-[var(--color-surface)]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-up mb-16">
      <p class="font-mono text-sm text-[var(--color-accent)] mb-3">{tr.ventures.label}</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">{tr.ventures.title}</h2>
      <p class="text-[var(--color-text-secondary)] mt-4 max-w-xl">{tr.ventures.sub}</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tr.ventures.items.map((v, i) => (
        <div class="venture-card fade-up rounded-xl border border-[var(--color-line)] bg-[var(--color-bg)] p-8 hover:border-[var(--color-line-accent)] hover:bg-[var(--color-surface-2)] transition-colors flex flex-col">
          <div class="mb-5 flex items-center justify-between">
            <span class={`text-[10px] font-mono font-medium px-2.5 py-1 rounded-sm border uppercase tracking-widest ${statusStyle[statusKey[i]]}`}>
              {v.statusLabel}
            </span>
            <span class="text-[var(--color-muted)]" set:html={buIcons[i]} />
          </div>

          <h3 class="text-xl font-bold mb-1">{v.name}</h3>
          <p class="text-sm font-mono text-[var(--color-accent)] mb-4">{v.tagline}</p>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6 flex-1">{v.description}</p>

          <div class="mt-auto space-y-2 mb-6">
            {v.metrics.map((m) => (
              <div class="text-xs font-mono text-[var(--color-muted)] flex items-center gap-2">
                <span class="text-[var(--color-accent-green)]">→</span> {m}
              </div>
            ))}
          </div>

          {urls[i] && (
            <a
              href={urls[i]}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-xs font-mono text-[var(--color-accent)] hover:gap-3 transition-all uppercase tracking-widest"
            >
              {tr.ventures.viewEntity} <span>→</span>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
