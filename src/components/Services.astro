---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const tr = t(lang);

const prices = ['$3K ~ $5K', '$10K ~ $25K', '$25K ~ $50K', '$3K ~ $8K / mo'];
const accents = [false, true, false, false];
---

<section id="services" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-up mb-16">
      <p class="font-mono text-sm text-[var(--color-accent)] mb-3">{tr.services.label}</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">{tr.services.title}</h2>
      <p class="text-[var(--color-text-secondary)] mt-4 max-w-xl">{tr.services.sub}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {tr.services.packages.map((pkg, i) => (
        <div
          class:list={[
            'fade-up rounded-xl p-8 border transition-colors',
            accents[i]
              ? 'bg-[var(--color-accent-dim)] border-[var(--color-line-accent)] glow-card'
              : 'bg-[var(--color-surface)] border-[var(--color-line)] hover:border-[var(--color-line-accent)]',
          ]}
        >
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="text-xl font-semibold">{pkg.name}</h3>
              <p class="font-mono text-sm text-[var(--color-muted)] mt-1">
                {pkg.timeline === 'Ongoing' ? tr.services.ongoingLabel : pkg.timeline}
              </p>
            </div>
            <div class="font-mono text-lg font-bold text-[var(--color-accent)]">{prices[i]}</div>
          </div>

          <p class="text-sm text-[var(--color-text-secondary)] mb-6 leading-relaxed">{pkg.description}</p>

          <ul class="space-y-2">
            {pkg.features.map((f) => (
              <li class="text-sm text-[var(--color-text-secondary)] flex items-start gap-2">
                <span class="text-[var(--color-accent-green)] mt-0.5 shrink-0">+</span>
                {f}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
